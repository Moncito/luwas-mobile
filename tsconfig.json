{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"],
      "@hooks/*": ["hooks/*"],
      "@lib/*": ["src/lib/*"],
      "@components/*": ["components/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["**/*.ts", "**/*.tsx", "src/types/firebase-react-native.d.ts"]
}
